# ── Salon Platform — environment configuration ──
# Copy to `.env` and adjust per deployment. All values have safe
# dev fallbacks, but you MUST set SESSION_SECRET and the admin
# credentials for any real (internet-facing) deployment.

# Server
PORT=3000
NODE_ENV=production

# Session — set to a long random string (e.g. `openssl rand -hex 32`)
SESSION_SECRET=replace-with-a-long-random-secret

# First admin account (used ONLY to seed the account on first run;
# afterwards change it from the admin panel). The password is hashed
# and stored in the database — it is never kept in plain text there.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Booking window (24h clock; end may cross midnight)
SLOT_START_HOUR=12
SLOT_END_HOUR=3
SLOT_DURATION=60

# Uploads
MAX_FILE_MB=50
# UPLOAD_DIR=/data/uploads
# DB_PATH=/data/salon.db
